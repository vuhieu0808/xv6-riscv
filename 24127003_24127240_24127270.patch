diff --git a/kernel/file.c b/kernel/file.c
index 8912b7e..3ff0099 100644
--- a/kernel/file.c
+++ b/kernel/file.c
@@ -178,3 +178,19 @@ filewrite(struct file *f, uint64 addr, int n)
   return ret;
 }
 
+// for code
+
+uint64 count_open_files(void) {
+  struct file *f;
+  uint64 count = 0;
+
+  acquire(&ftable.lock);
+  for (f = ftable.file; f < ftable.file + NFILE; f++) {
+    if (f->ref > 0) {
+      count++;
+    }
+  }
+  release(&ftable.lock);
+
+  return count;
+}
