diff --git a/user/sysinfotest.c b/user/sysinfotest.c
new file mode 100644
index 0000000..059ffa6
--- /dev/null
+++ b/user/sysinfotest.c
@@ -0,0 +1,15 @@
+#include "kernel/types.h"
+#include "kernel/sysinfo.h"
+#include "user/user.h"
+
+int main(int argc, char *argv[]) {
+  struct sysinfo info;
+  if (sysinfo(&info) < 0) {
+    fprintf(2, "sysinfo failed\n");
+    exit(1);
+  }
+  printf("freemem: %ld bytes\n", info.freemem);
+  printf("nproc: %ld\n", info.nproc);
+  printf("nopenfiles: %ld\n", info.nopenfiles);
+  exit(0);
+}
